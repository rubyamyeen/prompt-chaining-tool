# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Supabase (client-side) - same values, different names for client components
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Site URL (for auth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Caption Generation API (api.almostcrackd.ai)
ALMOSTCRACKD_API_URL=https://api.almostcrackd.ai
ALMOSTCRACKD_API_KEY=your-api-key
